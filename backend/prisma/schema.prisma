generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One row per institution (tenant). Setup tiles store JSON for flexibility until Excel schema arrives.
model Institution {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  setup     InstitutionSetup?
  holidays  Holiday[]
  enquiries Enquiry[]
}

enum EnquiryStatus {
  NEW
  IN_PROCESS
  FOLLOW_UP
  CONVERTED
  NOT_INTERESTED
}

enum EnquiryActivityType {
  SYSTEM
  CALL
  EMAIL
  SMS
  STATUS_CHANGE
  NOTE
  MEETING
  VISIT
  ASSIGN
}

/// Admission CRM — student / parent enquiries
model Enquiry {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  enquiryId       String
  enquiryDate     DateTime @default(now())
  enquirerName    String
  mobile          String
  email           String   @default("")
  classInterested String   @default("")
  source          String   @default("Website")
  status          EnquiryStatus @default(NEW)
  assignedTo      String   @default("")
  nextFollowUp    DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities EnquiryActivity[]
  tasks      FollowUpTask[]

  @@unique([institutionId, enquiryId])
  @@index([institutionId, status])
  @@index([institutionId, enquiryDate])
  @@index([institutionId, source])
}

model EnquiryActivity {
  id         String              @id @default(cuid())
  enquiryId  String
  enquiry    Enquiry             @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  type       EnquiryActivityType @default(SYSTEM)
  description String
  performedBy String             @default("System")
  createdAt  DateTime            @default(now())

  @@index([enquiryId, createdAt])
}

model FollowUpTask {
  id         String   @id @default(cuid())
  enquiryId  String
  enquiry    Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  title      String
  assignedTo String   @default("")
  dueDate    DateTime
  status     String   @default("Pending") // Pending | Completed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enquiryId, dueDate])
  @@index([dueDate, status])
}

enum HolidayType {
  NATIONAL
  RESTRICTED
  OPTIONAL
  INSTITUTIONAL
  OTHER
}

enum HolidayAudience {
  ALL
  STAFF
  STUDENTS
}

/// Shared holiday master — used by Institution Setup + HR/Payroll calendar
model Holiday {
  id            String          @id @default(cuid())
  institutionId String
  institution   Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  date        DateTime        @db.Date
  name        String
  type        HolidayType     @default(NATIONAL)
  applicableTo HolidayAudience @default(ALL)
  isPaid      Boolean         @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, date, name])
  @@index([institutionId, date])
}

model InstitutionSetup {
  id            String @id @default(cuid())
  institutionId String @unique
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  /// Keys match Institution Setup tiles (basicInformation, academicSetup, ...)
  basicInformation   Json @default("{}")
  academicSetup      Json @default("{}")
  classesSections    Json @default("{}")
  subjectsSetup      Json @default("{}")
  departmentsSetup   Json @default("{}")
  sessionTermSetup   Json @default("{}")
  gradeMarksSetup    Json @default("{}")
  feeGroupSetup      Json @default("{}")
  documentSetup      Json @default("{}")
  idCardNumbering    Json @default("{}")
  calendarSetup      Json @default("{}")
  customFieldsSetup  Json @default("{}")
  notificationSetup  Json @default("{}")
  otherPreferences   Json @default("{}")
  integrationSetup   Json @default("{}")
  backupRecovery     Json @default("{}")
  securitySettings   Json @default("{}")
  dataImportExport   Json @default("{}")

  expressSetupCompletedAt DateTime?
  lastExpressImportMeta   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
