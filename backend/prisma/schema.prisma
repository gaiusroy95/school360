  institutionId       String
  institution         Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId            String
  academicYear        String   @default("2025-26")
  term                String   @default("Term 1")
  title               String
  category            String   @default("PHYSICAL_HEALTH")
  subCategory         String   @default("")
  activityType        String   @default("")
  className           String   @default("")
  sectionName         String   @default("")
  teacherName         String   @default("")
  coTeacherName       String   @default("")
  activityDate        DateTime
  startDate           DateTime?
  endDate             DateTime?
  venue               String   @default("")
  description         String   @default("")
  measurementCriteria String   @default("")
  maxScore            Int      @default(100)
  status              CoScholasticActivityStatus @default(PLANNED)
  publishedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  performances AcademicCoScholasticPerformance[]
  feedbacks    AcademicCoScholasticFeedback[]

  @@unique([institutionId, recordId])
  @@index([institutionId, academicYear])
  @@index([institutionId, category])
  @@index([institutionId, teacherName])
}

model AcademicCoScholasticPerformance {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId      String
  activityId    String
  activity      AcademicCoScholasticActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId     String
  studentName   String   @default("")
  className     String   @default("")
  sectionName   String   @default("")
  performanceScore Float @default(0)
  performanceGrade String @default("")
  performanceBand  CoScholasticPerformanceBand @default(AVERAGE)
  remarks       String   @default("")
  recordedBy    String   @default("")
  recordedAt    DateTime?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([institutionId, recordId])
  @@unique([institutionId, activityId, studentId])
  @@index([institutionId, studentId])
  @@index([institutionId, activityId])
}

model AcademicCoScholasticFeedback {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId      String
  activityId    String
  activity      AcademicCoScholasticActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId     String
  parentName    String   @default("")
