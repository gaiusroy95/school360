generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One row per institution (tenant). Setup tiles store JSON for flexibility until Excel schema arrives.
model Institution {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  setup     InstitutionSetup?
  holidays  Holiday[]
  enquiries Enquiry[]
  applications Application[]
  admissionTests AdmissionTest[]
  admissionTestSettings AdmissionTestSettings?
  seatCapacities SeatCapacity[]
  seatAllocations SeatAllocation[]
  admissionRecords AdmissionRecord[]
  feeReceipts FeeReceipt[]
  students Student[]
  studentCategories StudentCategory[]
  studentCategoryAssignments StudentCategoryAssignment[]
  studentBulkImports StudentBulkImport[]
  studentReports StudentReport[]
  studentAnalyticsRecords StudentAnalyticsRecord[]
  parentCategories ParentCategory[]
  parentCategoryAssignments ParentCategoryAssignment[]
  parentEngagementEvents ParentEngagementEvent[]
  parentCommunications ParentCommunication[]
  parentFeedbacks ParentFeedback[]
  parentMeetings ParentMeeting[]
  parentConsentTemplates ParentConsentTemplate[]
  parentConsentResponses ParentConsentResponse[]
  parentAppSessions ParentAppSession[]
  academicClassSections AcademicClassSection[]
  academicSubjects AcademicSubject[]
  academicSubjectAllocations AcademicSubjectAllocation[]
  academicSyllabusChapters AcademicSyllabusChapter[]
  academicTimetableSlots AcademicTimetableSlot[]
  academicLessonPlans AcademicLessonPlan[]
  academicHomework AcademicHomework[]
  academicCalendarEvents AcademicCalendarEvent[]
  academicCceRecords AcademicCceRecord[]
  academicCoScholasticActivities AcademicCoScholasticActivity[]
  academicTeacherAllocations AcademicTeacherAllocation[]
  academicCurricula AcademicCurriculum[]
  studentSubjectElectives StudentSubjectElective[]
  academicClassTests AcademicClassTest[]
  academicClassTestScores AcademicClassTestScore[]
  academicBoardCalendarUploads AcademicBoardCalendarUpload[]
  academicTeacherDevCycles AcademicTeacherDevCycle[]
  academicTeacherEvaluations AcademicTeacherEvaluation[]
  academicCoScholasticPerformances AcademicCoScholasticPerformance[]
  academicCoScholasticFeedbacks AcademicCoScholasticFeedback[]
  academicTeacherRosterTasks AcademicTeacherRosterTask[]
  attendanceSessions AttendanceSession[]
  studentLeaveApplications StudentLeaveApplication[]
  teacherAttendanceProfiles TeacherAttendanceProfile[]
  teacherAttendanceDailyRecords TeacherAttendanceDailyRecord[]
  teacherLeaveGrants TeacherLeaveGrant[]
  staffAttendanceProfiles StaffAttendanceProfile[]
  staffAttendanceDailyRecords StaffAttendanceDailyRecord[]
  staffLeaveGrants StaffLeaveGrant[]
  teacherSubstituteAssignments TeacherSubstituteAssignment[]
  teacherLeaveApplications TeacherLeaveApplication[]
  staffLeaveApplications StaffLeaveApplication[]
  studentGatePasses StudentGatePass[]
  attendanceTimelineConfig AttendanceTimelineConfig?
  attendanceGeoFences AttendanceGeoFence[]
  biometricDevices BiometricDevice[]
  biometricEnrollments BiometricEnrollment[]
  biometricAttendancePunches BiometricAttendancePunch[]
}

enum EnquiryStatus {
  NEW
  IN_PROCESS
  FOLLOW_UP
  CONVERTED
  NOT_INTERESTED
}

enum EnquiryActivityType {
  SYSTEM
  CALL
  EMAIL
  SMS
  STATUS_CHANGE
  NOTE
  MEETING
  VISIT
  ASSIGN
}

/// Admission CRM — student / parent enquiries
model Enquiry {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  enquiryId       String
  enquiryDate     DateTime @default(now())
  enquirerName    String
  mobile          String
  email           String   @default("")
  classInterested String   @default("")
  source          String   @default("Website")
  status          EnquiryStatus @default(NEW)
  assignedTo      String   @default("")
  nextFollowUp    DateTime?
  notes           String?
  lastContactedAt DateTime?
  lastSentiment   String?
  lastEngagement  String?
  lastRiskFactor  String?
  lastRiskDetails String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities     EnquiryActivity[]
  tasks          FollowUpTask[]
  applications   Application[]
  counselingLogs CounselingLog[]

  @@unique([institutionId, enquiryId])
  @@index([institutionId, status])
  @@index([institutionId, enquiryDate])
  @@index([institutionId, source])
}

model EnquiryActivity {
  id         String              @id @default(cuid())
  enquiryId  String
  enquiry    Enquiry             @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  type       EnquiryActivityType @default(SYSTEM)
  description String
  performedBy String             @default("System")
  createdAt  DateTime            @default(now())

  @@index([enquiryId, createdAt])
}

model FollowUpTask {
  id         String   @id @default(cuid())
  enquiryId  String
  enquiry    Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  title      String
  mode       FollowUpMode @default(PHONE)
  subject    String   @default("")
  discussionNotes String?
  assignedTo String   @default("")
  dueDate    DateTime
  status     String   @default("Pending") // Pending | Completed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enquiryId, dueDate])
  @@index([dueDate, status])
  @@index([mode, status])
}

enum FollowUpMode {
  PHONE
  CAMPUS_VISIT
  VIDEO_CALL
  EMAIL
  IN_PERSON_COUNSELLING
}

/// Immutable counseling session log (manual counselor assessment)
model CounselingLog {
  id              String   @id @default(cuid())
  enquiryId       String
  enquiry         Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  interactionType String
  sentiment       String
  engagement      String
  riskFactor      String
  riskDetails     String?
  remarks         String
  actionIntent    String
  nextFollowUp    DateTime?
  counselorName   String   @default("")
  createdAt       DateTime @default(now())

  @@index([enquiryId, createdAt])
  @@map("counseling_logs")
}

enum ApplicationStatus {
  PENDING_VERIFICATION
  VERIFIED
  APPROVED
  REJECTED
}

enum ApplicationDocumentType {
  BIRTH_CERTIFICATE
  PREVIOUS_MARKSHEET
  ADDRESS_PROOF
  OTHER
}

/// Admission application submitted by counselor from an enquiry
model Application {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  enquiryId     String?
  enquiry       Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)

  applicationId String
  submittedAt   DateTime @default(now())
  submittedBy   String   @default("")

  studentName   String
  dateOfBirth   DateTime? @db.Date
  fatherName    String   @default("")
  motherName    String   @default("")
  placeOfBirth  String   @default("")
  classApplied  String   @default("")
  mobile        String   @default("")
  email         String   @default("")
  address       String   @default("")

  entranceTestScore Float?
  entranceTestMax   Float?  @default(100)

  status            ApplicationStatus @default(PENDING_VERIFICATION)
  reviewedBy        String?
  reviewedAt        DateTime?
  approvalRemarks   String?
  rejectionRemarks  String?
  notes             String?

  documents ApplicationDocument[]
  entranceCredentials EntranceExamCredential[]
  seatAllocation SeatAllocation?
  admissionRecord AdmissionRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, applicationId])
  @@index([institutionId, status])
  @@index([institutionId, submittedAt])
  @@index([enquiryId])
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type            ApplicationDocumentType
  fileName        String
  mimeType        String   @default("application/pdf")
  /// Base64 payload (no data: prefix) — suitable for MVP document preview
  fileData        String   @db.Text
  /// Values recorded from the uploaded document for verification
  extractedFields Json     @default("{}")

  uploadedAt DateTime @default(now())
  uploadedBy String   @default("")

  @@index([applicationId, type])
}

enum HolidayType {
  NATIONAL
  RESTRICTED
  OPTIONAL
  INSTITUTIONAL
  OTHER
}

enum HolidayAudience {
  ALL
  STAFF
  STUDENTS
}

/// Shared holiday master — used by Institution Setup + HR/Payroll calendar
model Holiday {
  id            String          @id @default(cuid())
  institutionId String
  institution   Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  date        DateTime        @db.Date
  name        String
  type        HolidayType     @default(NATIONAL)
  applicableTo HolidayAudience @default(ALL)
  isPaid      Boolean         @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, date, name])
  @@index([institutionId, date])
}

model InstitutionSetup {
  id            String @id @default(cuid())
  institutionId String @unique
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  /// Keys match Institution Setup tiles (basicInformation, academicSetup, ...)
  basicInformation   Json @default("{}")
  academicSetup      Json @default("{}")
  classesSections    Json @default("{}")
  subjectsSetup      Json @default("{}")
  departmentsSetup   Json @default("{}")
  sessionTermSetup   Json @default("{}")
  gradeMarksSetup    Json @default("{}")
  feeGroupSetup      Json @default("{}")
  documentSetup      Json @default("{}")
  idCardNumbering    Json @default("{}")
  calendarSetup      Json @default("{}")
  customFieldsSetup  Json @default("{}")
  notificationSetup  Json @default("{}")
  otherPreferences   Json @default("{}")
  integrationSetup   Json @default("{}")
  backupRecovery     Json @default("{}")
  securitySettings   Json @default("{}")
  dataImportExport   Json @default("{}")

  expressSetupCompletedAt DateTime?
  lastExpressImportMeta   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AdmissionTestStatus {
  DRAFT
  PUBLISHED
}

enum AdmissionTestSource {
  PDF
  OCR
  SYLLABUS
  MANUAL
}

enum TestQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum TestDifficulty {
  EASY
  MEDIUM
  HARD
}

/// Admission entrance test (Phase 1: draft builder from PDF + AI)
model AdmissionTest {
  id              String              @id @default(cuid())
  institutionId   String
  institution     Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  title           String
  status          AdmissionTestStatus @default(DRAFT)
  source          AdmissionTestSource @default(PDF)
  durationMinutes Int                 @default(60)
  numQuestions    Int                 @default(50)
  questionType    String              @default("Multiple Choice")
  difficulty      String              @default("Medium")
  sourceFilesMeta Json                @default("[]")
  createdBy       String              @default("")
  passMarksPercent  Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  questions       TestQuestion[]
  publication     TestPublication?

  @@index([institutionId, status])
  @@index([institutionId, createdAt])
}

model TestQuestion {
  id            String           @id @default(cuid())
  testId        String
  test          AdmissionTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  sortOrder     Int
  type          TestQuestionType
  difficulty    TestDifficulty
  questionText  String
  options       Json?
  correctAnswer String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([testId, sortOrder])
}

enum PublicationDestination {
  ENTRANCE_EXAM_PORTAL
}

enum PublicationVisibility {
  WEB
  APP
  BOTH
}

model TestPublication {
  id              String                 @id @default(cuid())
  testId          String                 @unique
  test            AdmissionTest          @relation(fields: [testId], references: [id], onDelete: Cascade)
  institutionId   String
  destination     PublicationDestination @default(ENTRANCE_EXAM_PORTAL)
  scheduledAt     DateTime
  durationMinutes Int
  visibleOn       PublicationVisibility  @default(BOTH)
  publishedAt     DateTime               @default(now())
  publishedBy     String                 @default("")
  credentials     EntranceExamCredential[]

  @@index([institutionId, scheduledAt])
}

model EntranceExamCredential {
  id            String   @id @default(cuid())
  publicationId String
  publication   TestPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tokenNumber   String   @unique
  pinHash       String
  pinPlain      String   @default("") // shown once to staff; cleared optional in prod
  deliveredAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  attempt       EntranceExamAttempt?

  @@unique([publicationId, applicationId])
  @@index([tokenNumber])
}

model EntranceExamAttempt {
  id           String   @id @default(cuid())
  credentialId String   @unique
  credential   EntranceExamCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  startedAt    DateTime @default(now())
  submittedAt  DateTime?
  answers      Json     @default("{}")
  score        Float?
  maxScore     Float?
  percentScore Float?
  passed       Boolean?
  resultBreakdown Json?
  createdAt    DateTime @default(now())
}

/// Institution-wide admission test defaults (pass marks, etc.)
model AdmissionTestSettings {
  id               String      @id @default(cuid())
  institutionId    String      @unique
  institution      Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  passMarksPercent Int         @default(40)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum SeatAllocationStatus {
  ALLOCATED
  WAITLISTED
}

/// Configurable seats per class & section for admission intake
model SeatCapacity {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  className     String
  sectionName   String
  totalSeats    Int
  academicYear  String      @default("2025-26")
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  allocations   SeatAllocation[]

  @@unique([institutionId, academicYear, className, sectionName])
  @@index([institutionId, academicYear])
  @@index([institutionId, className])
}

/// Seat assigned (or waitlisted) from entrance-test merit ranking
model SeatAllocation {
  id              String               @id @default(cuid())
  institutionId   String
  institution     Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  applicationId   String               @unique
  application     Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  capacityId      String?
  capacity        SeatCapacity?        @relation(fields: [capacityId], references: [id], onDelete: SetNull)
  className       String
  sectionName     String               @default("")
  meritRank       Int
  classMeritRank  Int
  entranceScore   Float
  status          SeatAllocationStatus
  academicYear    String               @default("2025-26")
  allocatedAt     DateTime             @default(now())
  allocatedBy     String               @default("SYSTEM")
  notes           String               @default("")

  @@index([institutionId, academicYear, status])
  @@index([institutionId, className, sectionName])
  @@index([capacityId])
}

enum AdmissionRecordStatus {
  PENDING_CONFIRMATION
  CONFIRMED
}

/// Final admission record — created when principal approves; confirmed on Admissions module
model AdmissionRecord {
  id                  String                @id @default(cuid())
  institutionId       String
  institution         Institution           @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  applicationId       String                @unique
  application         Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  admissionNumber     String?
  className           String
  sectionName         String                @default("")
  academicYear        String                @default("2025-26")
  status              AdmissionRecordStatus @default(PENDING_CONFIRMATION)
  principalApprovedBy String                @default("")
  principalApprovedAt DateTime?
  confirmedAt         DateTime?
  confirmedBy         String                @default("")
  notes               String                @default("")
  feeReceipts         FeeReceipt[]
  student             Student?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([institutionId, admissionNumber])
  @@index([institutionId, academicYear, status])
  @@index([institutionId, className, sectionName])
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  PASSOUT
  TRANSFERRED
}

enum StudentGender {
  MALE
  FEMALE
  OTHER
}

/// Enrolled student roster — promoted from confirmed admissions or added manually
model Student {
  id                String         @id @default(cuid())
  institutionId     String
  institution       Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  admissionRecordId String?        @unique
  admissionRecord   AdmissionRecord? @relation(fields: [admissionRecordId], references: [id], onDelete: SetNull)

  admissionNumber   String
  rollNumber        String         @default("")
  rfidTag           String         @default("")

  firstName         String
  lastName          String         @default("")
  dateOfBirth       DateTime?      @db.Date
  gender            StudentGender  @default(OTHER)
  bloodGroup        String         @default("")
  aadhaarNumber     String         @default("")
  religion          String         @default("")
  nationality       String         @default("Indian")
  category          String         @default("General")
  placeOfBirth      String         @default("")
  address           String         @default("")
  mobile            String         @default("")
  email             String         @default("")
  photoUrl          String         @default("")

  className         String
  sectionName       String         @default("")
  academicYear      String         @default("2025-26")
  house             String         @default("")

  fatherName        String         @default("")
  fatherMobile      String         @default("")
  motherName        String         @default("")
  motherMobile      String         @default("")

  status            StudentStatus  @default(ACTIVE)
  enrolledAt        DateTime       @default(now())
  leftAt            DateTime?
  leftReason        String         @default("")

  documents         Json           @default("{}")
  customFields      Json           @default("{}")
  entranceScore     Float?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  categoryAssignments StudentCategoryAssignment[]
  analyticsRecords StudentAnalyticsRecord[]
  classTestScores AcademicClassTestScore[]
  attendanceRecords AttendanceRecord[]
  leaveApplications StudentLeaveApplication[]
  gatePasses StudentGatePass[]
  biometricEnrollments BiometricEnrollment[]

  @@unique([institutionId, admissionNumber])
  @@index([institutionId, academicYear, status])
  @@index([institutionId, className, sectionName])
  @@index([institutionId, gender])
  @@index([institutionId, category])
}

enum FeePaymentMode {
  CASH
  UPI
  CARD
  CHEQUE
  BANK_TRANSFER
}

/// Admission fee collection receipt (configured via Institution Setup → Fee Group)
model FeeReceipt {
  id                  String           @id @default(cuid())
  institutionId       String
  institution         Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  admissionRecordId   String?
  admissionRecord     AdmissionRecord?   @relation(fields: [admissionRecordId], references: [id], onDelete: SetNull)
  receiptNumber       String
  studentName         String
  admissionNumber     String             @default("")
  className           String
  sectionName         String             @default("")
  academicYear        String             @default("2025-26")
  paymentMode         FeePaymentMode
  amountPaid          Float
  feeBreakdown        Json
  remarks             String             @default("")
  collectedBy         String             @default("")
  collectedAt         DateTime           @default(now())
  institutionSnapshot Json               @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([institutionId, receiptNumber])
  @@index([institutionId, collectedAt])
  @@index([admissionRecordId])
}

enum StudentCategoryGroup {
  ADMISSION
  TALENT
  ATTENDANCE
  GOVERNMENT_RESERVATION
}

enum CategoryType {
  GOVERNMENT
  INTERNAL
}

enum StudentCategoryStatus {
  ACTIVE
  INACTIVE
}

enum CategoryAssignmentStatus {
  ACTIVE
  PENDING
  DRAFT
  DUE
  OPEN
  COMPLETED
  APPROVED
  PAID
}

/// Master category definitions (Admission, Talent, Attendance, Govt Reservation)
model StudentCategory {
  id            String                @id @default(cuid())
  institutionId String
  institution   Institution           @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  categoryGroup StudentCategoryGroup
  name          String
  shortCode     String
  categoryType  CategoryType          @default(INTERNAL)
  description   String                @default("")
  status        StudentCategoryStatus @default(ACTIVE)
  displayOrder  Int                   @default(0)
  colorCode     String                @default("#6366f1")
  icon          String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  assignments   StudentCategoryAssignment[]

  @@unique([institutionId, categoryGroup, shortCode])
  @@index([institutionId, categoryGroup, status])
}

/// Links students to categories
model StudentCategoryAssignment {
  id            String                   @id @default(cuid())
  institutionId String
  institution   Institution              @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  categoryId    String
  category      StudentCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recordId      String
  details       String                   @default("")
  status        CategoryAssignmentStatus @default(ACTIVE)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([studentId, categoryId])
  @@unique([institutionId, recordId])
  @@index([institutionId, status])
  @@index([categoryId])
}

enum BulkImportStatus {
  DRAFT
  PENDING
  OPEN
  ACTIVE
  COMPLETED
  APPROVED
  PAID
  DUE
}

enum BulkImportRowStatus {
  PENDING
  SUCCESS
  UPDATED
  ERROR
  SKIPPED
}

/// Bulk student import batch (one row per import job in UI)
model StudentBulkImport {
  id             String           @id @default(cuid())
  institutionId  String
  institution    Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId       String
  fileName       String           @default("")
  className      String           @default("")
  sectionName    String           @default("")
  academicYear   String           @default("2025-26")
  status         BulkImportStatus @default(PENDING)
  totalRows      Int              @default(0)
  createdCount   Int              @default(0)
  updatedCount   Int              @default(0)
  errorCount     Int              @default(0)
  details        String           @default("")
  updateExisting Boolean          @default(true)
  errors         Json             @default("[]")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  rows           StudentBulkImportRow[]

  @@unique([institutionId, recordId])
  @@index([institutionId, status])
  @@index([institutionId, createdAt])
  @@index([institutionId, className, sectionName])
}

/// Individual rows within a bulk import batch
model StudentBulkImportRow {
  id              String              @id @default(cuid())
  batchId         String
  batch           StudentBulkImport   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowNumber       Int
  studentName     String              @default("")
  className       String              @default("")
  sectionName     String              @default("")
  admissionNumber String              @default("")
  mobile          String              @default("")
  status          BulkImportRowStatus @default(PENDING)
  message         String              @default("")
  studentId       String?
  rawData         Json                @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([batchId])
  @@index([batchId, status])
}

enum StudentReportType {
  ACTIVE_INACTIVE
  CLASS_TOPPERS
  ABSENT_CLASS
  ID_CARD
  RFID_BIOMETRIC
  CUSTOM
}

enum StudentReportStatus {
  DRAFT
  PENDING
  OPEN
  ACTIVE
  COMPLETED
  APPROVED
  PAID
  DUE
}

/// Generated student report instance (one row in Reports table)
model StudentReport {
  id            String              @id @default(cuid())
  institutionId String
  institution   Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId      String
  reportType    StudentReportType
  name          String
  period        String              @default("")
  className     String              @default("")
  sectionName   String              @default("")
  academicYear  String              @default("2025-26")
  status        StudentReportStatus @default(COMPLETED)
  config        Json                @default("{}")
  data          Json                @default("{}")
  generatedAt   DateTime            @default(now())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

