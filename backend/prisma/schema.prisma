  staffType     String          @default("TEACHING")
  classSubject  String          @default("")
  kpiScore      Float           @default(0)
  competencyScore Float         @default(0)
  attendanceScore Float         @default(0)
  behaviourScore Float          @default(0)
  feedbackScore Float           @default(0)
  innovationScore Float         @default(0)
  trainingScore Float           @default(0)
  taskActionScore Float         @default(0)
  improvementScore Float        @default(0)
  parentEngScore Float           @default(0)
  parentFbScore Float           @default(0)
  studentFbScore Float          @default(0)
  overallScore  Float           @default(0)
  ratingBand    String          @default("")
  outcome       String          @default("")
  workflowStage String          @default("SELF") // SELF, MANAGER, HOD, PRINCIPAL, HR, MANAGEMENT, FINAL
  status        String          @default("DRAFT") // DRAFT, IN_REVIEW, COMPLETED, PUBLISHED
  selfRemarks   String          @default("")
  managerRemarks String         @default("")
  hodRemarks    String          @default("")
  principalRemarks String       @default("")
  hrRemarks     String          @default("")
  kpiDetails    Json            @default("[]")
  competencyDetails Json        @default("[]")
  publishedToMobile Boolean     @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([employeeId, cycleId])
  @@index([institutionId, academicYear, quarter])
  @@index([cycleId])
}

