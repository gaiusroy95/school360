# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000,https://school360-weld.vercel.app

# Neon PostgreSQL
# DATABASE_URL — pooled connection (use for the running API; hostname contains "-pooler")
# DIRECT_DATABASE_URL — direct connection (required for prisma migrate; hostname has NO "-pooler")
# Example pooled:  postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Example direct:   postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# JWT auth
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Google Gemini — server-side only (admission test AI question generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
