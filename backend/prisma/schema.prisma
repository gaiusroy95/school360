model BiometricDevice {
  id               String               @id @default(cuid())
  institutionId    String
  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId         String
  name             String
  deviceType       BiometricDeviceType
  status           BiometricDeviceStatus @default(ACTIVE)
  location         String               @default("")
  serialNumber     String               @default("")
  geoFenceId       String?
  geoFence         AttendanceGeoFence?  @relation(fields: [geoFenceId], references: [id], onDelete: SetNull)
  supportsStudents Boolean              @default(true)
  supportsTeachers Boolean              @default(true)
  supportsStaff    Boolean              @default(true)
  requiresGeoFence Boolean              @default(true)
  lastSyncAt       DateTime?
  notes            String               @default("")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  enrollments BiometricEnrollment[]
  punches     BiometricAttendancePunch[]

  @@unique([institutionId, recordId])
  @@index([institutionId, status])
}

model BiometricEnrollment {
