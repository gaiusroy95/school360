  punches BiometricAttendancePunch[]

  @@unique([institutionId, recordId])
  @@index([institutionId, isActive])
}

model BiometricDevice {
  id               String               @id @default(cuid())
  institutionId    String
  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId         String
  name             String
  deviceType       BiometricDeviceType
  status           BiometricDeviceStatus @default(ACTIVE)
  location         String               @default("")
  serialNumber     String               @default("")
  geoFenceId       String?
  geoFence         AttendanceGeoFence?  @relation(fields: [geoFenceId], references: [id], onDelete: SetNull)
  supportsStudents Boolean              @default(true)
  supportsTeachers Boolean              @default(true)
  supportsStaff    Boolean              @default(true)
  requiresGeoFence Boolean              @default(true)
  lastSyncAt       DateTime?
  notes            String               @default("")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  enrollments BiometricEnrollment[]
  punches     BiometricAttendancePunch[]

  @@unique([institutionId, recordId])
  @@index([institutionId, status])
}

model BiometricEnrollment {
  id                  String              @id @default(cuid())
  institutionId       String
  institution         Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId            String
  personType          BiometricPersonType
  studentId           String?
  student             Student?            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherProfileId    String?
  teacherProfile      TeacherAttendanceProfile? @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  staffProfileId      String?
  staffProfile        StaffAttendanceProfile? @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  academicYear        String              @default("2025-26")
  rfidCardId          String              @default("")
  biometricTemplateId String              @default("")
  deviceId            String?
  device              BiometricDevice?    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  isActive            Boolean             @default(true)
  enrolledBy          String              @default("")
  enrolledAt          DateTime            @default(now())
  notes               String              @default("")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([institutionId, recordId])
  @@index([institutionId, personType, isActive])
  @@index([institutionId, rfidCardId])
}

model BiometricAttendancePunch {
  id                 String                     @id @default(cuid())
  institutionId      String
  institution        Institution                @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId           String
  personType         BiometricPersonType
  personId           String
  personName         String
  personCode         String                     @default("")
  classGroup         String                     @default("")
  deviceId           String?
  device             BiometricDevice?           @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  deviceType         BiometricDeviceType
  eventType          BiometricAttendanceEventType
  punchStatus        BiometricPunchStatus
  verificationMethod String                     @default("BIOMETRIC")
  rfidCardId         String                     @default("")
  latitude           Float?
  longitude          Float?
  distanceMeters     Float?
  withinGeoFence     Boolean                    @default(false)
  geoFenceId         String?
  geoFence           AttendanceGeoFence?          @relation(fields: [geoFenceId], references: [id], onDelete: SetNull)
  geoFenceName       String                     @default("")
  remarks            String                     @default("")
  punchedAt          DateTime                   @default(now())
  createdAt          DateTime                   @default(now())

  @@unique([institutionId, recordId])
  @@index([institutionId, punchedAt])
  @@index([institutionId, personType, punchStatus])
}
