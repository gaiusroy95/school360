  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  code          String
  name          String
  groupName     String        @default("")
  status        FeeMasterStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  heads         ExpenseHead[]
  entries       ExpenseEntry[]
  budgets       ExpenseBudget[]

  @@unique([institutionId, code])
  @@index([institutionId, groupName])
}

model ExpenseHead {
  id            String          @id @default(cuid())
  institutionId String
  institution   Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  code          String
  name          String
  status        FeeMasterStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  entries       ExpenseEntry[]
  recurring     ExpenseRecurring[]

  @@unique([institutionId, code])
  @@index([categoryId])
}

model ExpenseVendor {
  id                 String           @id @default(cuid())
  institutionId      String
  institution        Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  vendorCode         String
  vendorName         String
  contactPerson      String           @default("")
  mobile             String           @default("")
  email              String           @default("")
  gstin              String           @default("")
  pan                String           @default("")
  bankAccount        String           @default("")
  bankIfsc           String           @default("")
  paymentTerms       String           @default("Net 30")
  outstandingBalance Float            @default(0)
  rating             Float            @default(0)
  contractExpiry     DateTime?        @db.Date
  amcExpiry          DateTime?        @db.Date
  status             FeeMasterStatus  @default(ACTIVE)
  remarks            String           @default("")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  entries            ExpenseEntry[]
  recurring          ExpenseRecurring[]

  @@unique([institutionId, vendorCode])
  @@index([institutionId, status])
}

model ExpenseEntry {
  id                String               @id @default(cuid())
  institutionId     String
  institution       Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  expenseId         String
  academicYear      String               @default("2025-26")
  expenseDate       DateTime             @db.Date
  categoryId        String
  category          ExpenseCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  headId            String?
  head              ExpenseHead?         @relation(fields: [headId], references: [id], onDelete: SetNull)
  department        String               @default("General")
  campus            String               @default("Main Campus")
  branch            String               @default("Main Branch")
  vendorId          String?
  vendor            ExpenseVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  invoiceNumber     String               @default("")
  purchaseOrderRef  String               @default("")
  paymentMethod     ExpensePaymentMethod @default(CASH)
  amount            Float                @default(0)
  gstAmount         Float                @default(0)
  cgst              Float                @default(0)
  sgst              Float                @default(0)
  igst              Float                @default(0)
  taxBreakdown      Json                 @default("{}")
  budgetCode        String               @default("")
  costCenter        String               @default("")
  description       String               @default("")
  billUploadName    String               @default("")
  status            ExpenseEntryStatus   @default(DRAFT)
  currentStage      ExpenseApprovalStage @default(STAFF)
  assetType         String               @default("")
  assetRef          String               @default("")
  recurringId       String?
  remarks           String               @default("")
  paidAt            DateTime?
  createdBy         String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvals         ExpenseApproval[]

  @@unique([institutionId, expenseId])
  @@index([institutionId, expenseDate, status])
  @@index([institutionId, academicYear, department])
  @@index([institutionId, campus])
  @@index([categoryId])
  @@index([vendorId])
}

model ExpenseApproval {
  id               String               @id @default(cuid())
  entryId          String
  entry            ExpenseEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  stage            ExpenseApprovalStage
  action           String               @default("APPROVE")
  actorName        String               @default("")
  remarks          String               @default("")
  digitalSignature String               @default("")
  signedAt         DateTime             @default(now())
  createdAt        DateTime             @default(now())

  @@index([entryId, stage])
}

model ExpenseBudget {
  id              String            @id @default(cuid())
  institutionId   String
  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  budgetCode      String
  name            String
  budgetType      ExpenseBudgetType @default(ANNUAL)
  academicYear    String            @default("2025-26")
  department      String            @default("")
  categoryId      String?
  category        ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  campus          String            @default("")
  periodStart     DateTime          @db.Date
  periodEnd       DateTime          @db.Date
  allocatedAmount Float             @default(0)
  alertThreshold  Float             @default(0.9)
  status          FeeMasterStatus   @default(ACTIVE)
  remarks         String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([institutionId, budgetCode])
  @@index([institutionId, academicYear, budgetType])
}

model ExpenseRecurring {
  id              String                    @id @default(cuid())
  institutionId   String
  institution     Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  templateCode    String
  name            String
  categoryId      String?
  headId          String?
  head            ExpenseHead?              @relation(fields: [headId], references: [id], onDelete: SetNull)
  vendorId        String?
  vendor          ExpenseVendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  amount          Float                     @default(0)
  frequency       ExpenseRecurringFrequency @default(MONTHLY)
  nextDueDate     DateTime                  @db.Date
  department      String                    @default("General")
  campus          String                    @default("Main Campus")
  paymentMethod   ExpensePaymentMethod      @default(BANK_TRANSFER)
  autoCreate      Boolean                   @default(false)
  status          FeeMasterStatus           @default(ACTIVE)
  lastGeneratedAt DateTime?
  remarks         String                    @default("")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([institutionId, templateCode])
  @@index([institutionId, status, nextDueDate])
}

model ExpenseReimbursement {
  id             String             @id @default(cuid())
  institutionId  String
  institution    Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  requestId      String
  academicYear   String             @default("2025-26")
  employeeName   String
  department     String             @default("General")
  amount         Float              @default(0)
  description    String             @default("")
  billUploadName String             @default("")
  status         ExpenseEntryStatus @default(PENDING_APPROVAL)
  approvedBy     String             @default("")
  approvedAt     DateTime?
  paidAt         DateTime?
  remarks        String             @default("")
  createdBy      String             @default("")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([institutionId, requestId])
  @@index([institutionId, status, academicYear])
}

