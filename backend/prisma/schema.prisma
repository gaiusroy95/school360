model AttendanceGeoFence {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId      String
  name          String
  description   String   @default("")
  latitude      Float
  longitude     Float
