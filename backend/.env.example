# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000,https://school360-weld.vercel.app

# Neon PostgreSQL
# DATABASE_URL — pooled connection (use for the running API; hostname contains "-pooler")
# DIRECT_DATABASE_URL — direct connection (required for prisma migrate; hostname has NO "-pooler")
# Example pooled:  postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Example direct:   postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# JWT auth
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Mobile apps — optional separate secret (falls back to JWT_SECRET)
MOBILE_JWT_SECRET=""
MOBILE_JWT_EXPIRES_IN="30d"
MOBILE_UPLOAD_MAX_BYTES=10485760

# Razorpay — parent fee payments
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Push notifications — Expo (ExponentPushToken) and legacy FCM HTTP
FCM_SERVER_KEY=""

# SMS / WhatsApp — absent alerts and parent messaging (MSG91)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_ROUTE="4"
WHATSAPP_API_URL=""
# Set to "sms" to force SMS instead of WhatsApp when both are configured
ABSENT_ALERT_CHANNEL=""

# Mobile OTP login (production) — set MOBILE_OTP_ENABLED=true to allow SMS OTP sign-in
MOBILE_OTP_ENABLED=false
# When true, password login is blocked; users must use OTP
MOBILE_OTP_REQUIRED=false
MSG91_OTP_TEMPLATE_ID=""

# Mobile reminder cron — fee + homework push reminders (every 5 min)
MOBILE_REMINDER_CRON_ENABLED=true

# Invigilation auto-rotation cron (runs at 5:00 AM IST when backend is running)
INVIGILATION_CRON_ENABLED=true
# Optional secret for external cron hitting POST /api/examination/invigilation/cron/rotate
CRON_SECRET=""

# Google Gemini — server-side only (admission test AI question generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
