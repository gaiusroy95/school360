  generatedBy          String            @default("")
  remarks              String            @default("")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([institutionId, slipNumber])
  @@unique([institutionId, employeeId, payPeriod])
  @@index([institutionId, payPeriod, status])
  @@index([institutionId, payYear, payMonth])
  @@index([employeeId])
