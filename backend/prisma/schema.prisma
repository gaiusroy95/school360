  institution          Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             PayrollEmployee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structureId          String?
  structure            PayrollSalaryStructure? @relation(fields: [structureId], references: [id], onDelete: SetNull)
  slipNumber           String
  payPeriod            String
  payMonth             Int
  payYear              Int
  workingDays          Float             @default(30)
  presentDays          Float             @default(30)
  leaveDays            Float             @default(0)
  basicSalary          Float             @default(0)
  hra                  Float             @default(0)
  da                   Float             @default(0)
  specialAllowance     Float             @default(0)
  conveyanceAllowance  Float             @default(0)
  otherAllowances      Float             @default(0)
  grossEarnings        Float             @default(0)
  epfEmployee          Float             @default(0)
  epfEmployer          Float             @default(0)
  esicEmployee         Float             @default(0)
  esicEmployer         Float             @default(0)
  professionalTax      Float             @default(0)
  tds                  Float             @default(0)
  otherDeductions      Float             @default(0)
  totalDeductions      Float             @default(0)
  netPay               Float             @default(0)
  status               PayrollSlipStatus @default(DRAFT)
  paidAt               DateTime?
  paidBy               String            @default("")
  generatedBy          String            @default("")
  remarks              String            @default("")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([institutionId, slipNumber])
  @@unique([institutionId, employeeId, payPeriod])
  @@index([institutionId, payPeriod, status])
  @@index([institutionId, payYear, payMonth])
  @@index([employeeId])
}

enum PaymentReconciliationStatus {
  DRAFT
  PENDING_APPROVAL
  RETURNED
  REJECTED
  FROZEN
  DAY_CLOSING_COMPLETED
}

enum PaymentReconciliationStage {
  CASHIER
  ACCOUNTS_EXECUTIVE
  ACCOUNTS_MANAGER
  FINANCE_HEAD
  PRINCIPAL_DIRECTOR
  COMPLETED
}

enum PaymentReconciliationAction {
  SUBMIT
  APPROVE
  REJECT
  RETURN_FOR_CORRECTION
  FREEZE
  SIGN
}

/// Daily payment reconciliation / day closing record
model PaymentReconciliation {
  id                     String                      @id @default(cuid())
  institutionId          String
  institution            Institution                 @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  reconciliationDate     DateTime                    @db.Date
  academicYear           String                      @default("2025-26")
  status                 PaymentReconciliationStatus @default(DRAFT)
  currentStage           PaymentReconciliationStage  @default(CASHIER)
  bankStatementTotal     Float                       @default(0)
  cashCount              Float                       @default(0)
  gatewaySettlement      Float                       @default(0)
  cashDepositedToBank    Float                       @default(0)
  cashWithdrawnFromBank  Float                       @default(0)
  cashPayments           Float                       @default(0)
  bankCharges            Float                       @default(0)
  openingPettyCash       Float                       @default(0)
  previousDayOutstanding Float                       @default(0)
  principalRequired      Boolean                     @default(false)
  snapshot               Json?
  frozenAt               DateTime?
  frozenBy               String                      @default("")
  completedAt            DateTime?
  submittedBy              String                      @default("")
  submittedAt              DateTime?
  pdfGeneratedAt           DateTime?
  remarks                  String                      @default("")
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  approvals                PaymentReconciliationApproval[]

  @@unique([institutionId, reconciliationDate])
  @@index([institutionId, status, reconciliationDate])
}

model PaymentReconciliationApproval {
  id                 String                      @id @default(cuid())
  reconciliationId   String
  reconciliation     PaymentReconciliation       @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  stage              PaymentReconciliationStage
  action             PaymentReconciliationAction
  actorName          String                      @default("")
  actorRole          String                      @default("")
  remarks            String                      @default("")
  digitalSignature   String                      @default("")
  signedAt           DateTime                    @default(now())
  createdAt          DateTime                    @default(now())

  @@index([reconciliationId, stage])
}

enum BankDepositStatus {
  PENDING
  APPROVED
  DEPOSITED
  REALIZED
  REJECTED
}

/// Cash deposit slip to bank
model BankCashDeposit {
  id                  String            @id @default(cuid())
  institutionId       String
  institution         Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  depositId           String
  academicYear        String            @default("2025-26")
  depositDate         DateTime          @db.Date
  depositTime         DateTime          @default(now())
  campus              String            @default("Main Campus")
  branch              String            @default("Main Branch")
  cashierName         String            @default("")
  depositBy           String            @default("")
  bankName            String            @default("")
  bankAccount         String            @default("")
  depositSlipNo       String            @default("")
  depositAmount       Float             @default(0)
  depositType         String            @default("Cash")
  collectionDate      DateTime          @db.Date
  totalCashCollected  Float             @default(0)
  cashCounted         Float             @default(0)
  difference          Float             @default(0)
  remarks             String            @default("")
  slipUploadName      String            @default("")
  status              BankDepositStatus @default(PENDING)
  approvedBy          String            @default("")
  approvedAt          DateTime?
  createdBy           String            @default("")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([institutionId, depositId])
  @@index([institutionId, depositDate, status])
  @@index([institutionId, academicYear])
}

/// Cheque deposit slip to bank
model BankChequeDeposit {
  id              String            @id @default(cuid())
  institutionId   String
  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  depositId       String
  academicYear    String            @default("2025-26")
  depositDate     DateTime          @db.Date
  bankName        String            @default("")
  branch          String            @default("")
  depositSlipNo   String            @default("")
  depositAmount   Float             @default(0)
  totalCheques    Int               @default(0)
  depositBy       String            @default("")
  remarks         String            @default("")
  status          BankDepositStatus @default(PENDING)
  approvedBy      String            @default("")
  approvedAt      DateTime?
  realizedAt      DateTime?
  createdBy       String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  items           BankChequeDepositItem[]

  @@unique([institutionId, depositId])
  @@index([institutionId, depositDate, status])
  @@index([institutionId, academicYear])
}

/// Individual cheques within a deposit slip
model BankChequeDepositItem {
  id              String            @id @default(cuid())
  depositId       String
  deposit         BankChequeDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  studentName     String            @default("")
  receiptNumber   String            @default("")
  bankName        String            @default("")
  chequeNumber    String            @default("")
  chequeBankBranch String           @default("")
  depositDate     DateTime          @db.Date
  amount          Float             @default(0)
  status          BankDepositStatus @default(DEPOSITED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([depositId])
  @@index([receiptNumber])
}

enum ExpenseEntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RETURNED
  PAID
}

enum ExpensePaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CARD
  ONLINE
  NEFT_RTGS
}

enum ExpenseBudgetType {
  ANNUAL
  MONTHLY
  DEPARTMENT
  CATEGORY
  BRANCH
  EVENT
  PROJECT
}

enum ExpenseRecurringFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ExpenseApprovalStage {
  STAFF
  DEPARTMENT_HEAD
  ACCOUNTS
  PRINCIPAL
  MANAGEMENT
  COMPLETED
}

model ExpenseCategory {
  id            String        @id @default(cuid())
  institutionId String
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  code          String
  name          String
  groupName     String        @default("")
  status        FeeMasterStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  heads         ExpenseHead[]
  entries       ExpenseEntry[]
  budgets       ExpenseBudget[]

  @@unique([institutionId, code])
  @@index([institutionId, groupName])
}

model ExpenseHead {
  id            String          @id @default(cuid())
  institutionId String
  institution   Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  code          String
  name          String
  status        FeeMasterStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  entries       ExpenseEntry[]
  recurring     ExpenseRecurring[]

  @@unique([institutionId, code])
  @@index([categoryId])
}

model ExpenseVendor {
  id                 String           @id @default(cuid())
  institutionId      String
  institution        Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  vendorCode         String
  vendorName         String
  contactPerson      String           @default("")
  mobile             String           @default("")
  email              String           @default("")
  gstin              String           @default("")
  pan                String           @default("")
  bankAccount        String           @default("")
  bankIfsc           String           @default("")
  paymentTerms       String           @default("Net 30")
  outstandingBalance Float            @default(0)
  rating             Float            @default(0)
  contractExpiry     DateTime?        @db.Date
  amcExpiry          DateTime?        @db.Date
  status             FeeMasterStatus  @default(ACTIVE)
  remarks            String           @default("")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  entries            ExpenseEntry[]
  recurring          ExpenseRecurring[]

  @@unique([institutionId, vendorCode])
  @@index([institutionId, status])
}

model ExpenseEntry {
  id                String               @id @default(cuid())
  institutionId     String
  institution       Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  expenseId         String
  academicYear      String               @default("2025-26")
  expenseDate       DateTime             @db.Date
  categoryId        String
  category          ExpenseCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  headId            String?
  head              ExpenseHead?         @relation(fields: [headId], references: [id], onDelete: SetNull)
  department        String               @default("General")
  campus            String               @default("Main Campus")
  branch            String               @default("Main Branch")
  vendorId          String?
  vendor            ExpenseVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  invoiceNumber     String               @default("")
  purchaseOrderRef  String               @default("")
  paymentMethod     ExpensePaymentMethod @default(CASH)
  amount            Float                @default(0)
  gstAmount         Float                @default(0)
  cgst              Float                @default(0)
  sgst              Float                @default(0)
  igst              Float                @default(0)
  taxBreakdown      Json                 @default("{}")
  budgetCode        String               @default("")
  costCenter        String               @default("")
  description       String               @default("")
  billUploadName    String               @default("")
  status            ExpenseEntryStatus   @default(DRAFT)
  currentStage      ExpenseApprovalStage @default(STAFF)
  assetType         String               @default("")
  assetRef          String               @default("")
  recurringId       String?
  remarks           String               @default("")
  paidAt            DateTime?
  createdBy         String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvals         ExpenseApproval[]

  @@unique([institutionId, expenseId])
  @@index([institutionId, expenseDate, status])
  @@index([institutionId, academicYear, department])
  @@index([institutionId, campus])
  @@index([categoryId])
  @@index([vendorId])
}

model ExpenseApproval {
  id               String               @id @default(cuid())
  entryId          String
  entry            ExpenseEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  stage            ExpenseApprovalStage
  action           String               @default("APPROVE")
  actorName        String               @default("")
  remarks          String               @default("")
  digitalSignature String               @default("")
  signedAt         DateTime             @default(now())
  createdAt        DateTime             @default(now())

  @@index([entryId, stage])
}

model ExpenseBudget {
  id              String            @id @default(cuid())
  institutionId   String
  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  budgetCode      String
  name            String
  budgetType      ExpenseBudgetType @default(ANNUAL)
  academicYear    String            @default("2025-26")
  department      String            @default("")
  categoryId      String?
  category        ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  campus          String            @default("")
  periodStart     DateTime          @db.Date
  periodEnd       DateTime          @db.Date
  allocatedAmount Float             @default(0)
  alertThreshold  Float             @default(0.9)
  status          FeeMasterStatus   @default(ACTIVE)
  remarks         String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([institutionId, budgetCode])
  @@index([institutionId, academicYear, budgetType])
}

model ExpenseRecurring {
  id              String                    @id @default(cuid())
  institutionId   String
  institution     Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  templateCode    String
  name            String
  categoryId      String?
  headId          String?
  head            ExpenseHead?              @relation(fields: [headId], references: [id], onDelete: SetNull)
  vendorId        String?
  vendor          ExpenseVendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  amount          Float                     @default(0)
  frequency       ExpenseRecurringFrequency @default(MONTHLY)
  nextDueDate     DateTime                  @db.Date
  department      String                    @default("General")
  campus          String                    @default("Main Campus")
  paymentMethod   ExpensePaymentMethod      @default(BANK_TRANSFER)
  autoCreate      Boolean                   @default(false)
  status          FeeMasterStatus           @default(ACTIVE)
  lastGeneratedAt DateTime?
  remarks         String                    @default("")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([institutionId, templateCode])
  @@index([institutionId, status, nextDueDate])
}

model ExpenseReimbursement {
  id             String             @id @default(cuid())
  institutionId  String
  institution    Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  requestId      String
  academicYear   String             @default("2025-26")
  employeeName   String
  department     String             @default("General")
  amount         Float              @default(0)
  description    String             @default("")
  billUploadName String             @default("")
  status         ExpenseEntryStatus @default(PENDING_APPROVAL)
  approvedBy     String             @default("")
  approvedAt     DateTime?
  paidAt         DateTime?
  remarks        String             @default("")
  createdBy      String             @default("")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([institutionId, requestId])
  @@index([institutionId, status, academicYear])
}

