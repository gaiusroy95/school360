/// Configurable weightage, rating scale, increment & promotion matrices
model HrPerformanceSettings {
  id                    String      @id @default(cuid())
  institutionId         String      @unique
  institution           Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  weightage             Json        @default("{\"kpi\":35,\"competency\":25,\"attendance\":10,\"behaviour\":10,\"feedback\":10,\"innovation\":5,\"training\":5}")
  ratingScale           Json        @default("[{\"rating\":5,\"label\":\"Outstanding\",\"min\":90,\"max\":100},{\"rating\":4,\"label\":\"Exceeds Expectations\",\"min\":80,\"max\":89},{\"rating\":3,\"label\":\"Meets Expectations\",\"min\":70,\"max\":79},{\"rating\":2,\"label\":\"Needs Improvement\",\"min\":60,\"max\":69},{\"rating\":1,\"label\":\"Unsatisfactory\",\"min\":0,\"max\":59}]")
  annualWeightage       Json        @default("{\"q1\":20,\"q2\":20,\"q3\":20,\"q4\":20,\"specialAchievement\":10,\"leadership\":10}")
  promotionMatrix       Json        @default("[{\"minScore\":95,\"outcome\":\"Fast Track Promotion\"},{\"minScore\":90,\"outcome\":\"Promotion Eligible\"},{\"minScore\":80,\"outcome\":\"Grade Upgrade\"},{\"minScore\":70,\"outcome\":\"Salary Increment Only\"},{\"minScore\":0,\"outcome\":\"Improvement Plan\"}]")
  incrementMatrix       Json        @default("[{\"band\":\"Outstanding\",\"minPercent\":15,\"maxPercent\":20},{\"band\":\"Excellent\",\"minPercent\":12,\"maxPercent\":15},{\"band\":\"Very Good\",\"minPercent\":8,\"maxPercent\":10},{\"band\":\"Good\",\"minPercent\":5,\"maxPercent\":7},{\"band\":\"Average\",\"minPercent\":2,\"maxPercent\":4},{\"band\":\"Poor\",\"minPercent\":0,\"maxPercent\":0}]")
  promotionRules        Json        @default("{\"minServiceMonths\":12,\"minAnnualScore\":70,\"noDisciplinary\":true,\"mandatoryTrainings\":true,\"budgetApproval\":true}")
  approvalMatrix        Json        @default("[{\"action\":\"Self Review\",\"level\":\"Employee\"},{\"action\":\"Performance Review\",\"level\":\"Reporting Manager\"},{\"action\":\"Department Review\",\"level\":\"HOD\"},{\"action\":\"Academic Review\",\"level\":\"Principal\"},{\"action\":\"HR Review\",\"level\":\"HR Manager\"},{\"action\":\"Budget Approval\",\"level\":\"Finance\"},{\"action\":\"Final Approval\",\"level\":\"Management\"}]")
  pipThreshold          Float       @default(70)
  pipDurationDays       Int         @default(90)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

