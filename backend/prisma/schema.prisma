model HrShift {
  id                    String      @id @default(cuid())
  institutionId         String
  institution           Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  code                  String
  name                  String
  shiftType             String      @default("REGULAR")
  description           String      @default("")
  startTime             String      @default("09:00")
  endTime               String      @default("17:00")
  breakStart            String      @default("")
  breakEnd              String      @default("")
  breakMinutes          Int         @default(60)
  totalHours            Float       @default(8)
  graceMinutes          Int         @default(15)
  lateMarkRule          String      @default("Mark late after grace period")
  earlyExitRule         String      @default("Deduction if exit before shift end")
  overtimeEligible      Boolean     @default(true)
  halfDayRule           String      @default("Less than 4 hours = Half Day")
  attendanceRule        String      @default("Standard biometric attendance")
