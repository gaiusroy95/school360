  da                   Float           @default(0)
  specialAllowance     Float           @default(0)
  conveyanceAllowance  Float           @default(0)
  otherAllowances      Float           @default(0)
  grossSalary          Float           @default(0)
  pfWages              Float           @default(0)
  epfEmployee          Float           @default(0)
  epfEmployer          Float           @default(0)
  esicEmployee         Float           @default(0)
  esicEmployer         Float           @default(0)
  professionalTax      Float           @default(0)
  tds                  Float           @default(0)
  otherDeductions      Float           @default(0)
  totalDeductions      Float           @default(0)
  netSalary            Float           @default(0)
  status               FeeMasterStatus @default(ACTIVE)
  remarks              String          @default("")
  createdBy            String          @default("")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  slips PayrollSlip[]

  @@unique([institutionId, structureCode])
  @@index([institutionId, employeeId, status])
  @@index([institutionId, effectiveFrom])
}

