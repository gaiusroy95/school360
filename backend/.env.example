# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000,https://school360-weld.vercel.app

# Neon PostgreSQL — use the *pooled* connection string from Neon dashboard.
# Format: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connect_timeout=30
# If you use a VPN, omit channel_binding=require (it can cause flaky connections).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connect_timeout=30"

# JWT auth
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Google Gemini — server-side only (admission test AI question generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
