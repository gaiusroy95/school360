enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
  HALF_DAY
}

enum AttendanceSessionMode {
  CLASS
  SUBJECT
  ACTIVITY
}

enum LeaveApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceSession {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  recordId      String
  academicYear  String   @default("2025-26")
  sessionDate   DateTime @db.Date
  className     String
  sectionName   String   @default("")
  subjectName   String   @default("")
  activityName  String   @default("")
  mode          AttendanceSessionMode @default(CLASS)
  markedBy      String   @default("")
  source        String   @default("MANUAL")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  records AttendanceRecord[]

  @@unique([institutionId, recordId])
  @@unique([institutionId, sessionDate, className, sectionName, mode, subjectName, activityName])
  @@index([institutionId, academicYear, sessionDate])
}

model AttendanceRecord {
  id           String   @id @default(cuid())
  sessionId    String
  session      AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       AttendanceStatus
  checkInTime  String   @default("")
  checkOutTime String   @default("")
  lateMinutes  Int      @default(0)
  earlyExitMinutes Int  @default(0)
  absentReason String   @default("")
  remarks      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sessionId, studentId])
  @@index([studentId, status])
}

