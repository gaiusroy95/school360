  isActive          Boolean       @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  devices           MobileDevice[]
  notifications     MobileNotification[]
  uploads           MobileUpload[]
